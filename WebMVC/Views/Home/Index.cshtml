@model HomePageViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="container-fluid py-5">
    <!-- Search Section -->
    <div class="row mb-5">
        <div class="col-md-8 offset-md-2">
            <form method="get" action="@Url.Action("Index", "Home")" class="input-group input-group-lg">
                <input 
                    type="text" 
                    name="searchTerm" 
                    class="form-control" 
                    placeholder="Search for books, authors, publishers, or genres..." 
                    value="@Model.SearchQuery"
                    aria-label="Search books" />
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search"></i> Search
                </button>
            </form>
        </div>
    </div>

    <!-- Results Header with Pagination Info -->
    <div class="row mb-4">
        <div class="col-12">
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <h2>Search Results for <span class="text-primary">@Model.SearchQuery</span></h2>
            }
            else
            {
                <h2>Featured Books</h2>
            }
            <p class="text-muted">
                @if (Model.TotalCount == 0)
                {
                    <span>No books found</span>
                }
                else
                {
                    <span>
                        Showing @((Model.PageNumber - 1) * Model.PageSize + 1) - @Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount) of @Model.TotalCount book(s)
                        @if (Model.TotalPages > 1)
                        {
                            <span> | Page @Model.PageNumber of @Model.TotalPages</span>
                        }
                    </span>
                }
            </p>
        </div>
    </div>

    <!-- Books Grid -->
    @if (Model.Books.Any())
    {
        <div class="row g-4">
            @foreach (var book in Model.Books)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 book-card" style="cursor: pointer;">
                        <!-- Book Image -->
                        <div class="position-relative" style="height: 250px; overflow: hidden; background-color: #f5f5f5;">
                            @if (!string.IsNullOrEmpty(book.ImageUrl))
                            {
                                <img 
                                    src="@book.ImageUrl" 
                                    class="card-img-top" 
                                    alt="@book.Title"
                                    style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100">
                                    <span class="text-muted">
                                        <i class="bi bi-image" style="font-size: 3rem;"></i>
                                    </span>
                                </div>
                            }
                        </div>

                        <!-- Card Body -->
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-truncate" title="@book.Title">@book.Title</h5>
                            
                            @if (!string.IsNullOrEmpty(book.FirstAuthorName))
                            {
                                <p class="card-text text-muted small text-truncate" title="@book.FirstAuthorName">
                                    by @book.FirstAuthorName
                                </p>
                            }
                            
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center gap-2">
                                    <span class="h5 mb-0 text-primary">$@book.Price.ToString("F2")</span>
                                    <button class="btn btn-sm btn-outline-primary" type="button">
                                        <i class="bi bi-cart-plus"></i> Add to Cart
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Card Footer -->
                        <div class="card-footer bg-light border-top-0">
                            <small class="text-muted d-block text-center">
                                Click to view details
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination Section -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Pagination" class="mt-5 mb-5">
                <ul class="pagination justify-content-center">
                    <!-- Previous Button -->
                    @if (Model.HasPreviousPage)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, pageNumber = Model.PageNumber - 1, pageSize = Model.PageSize })">
                                Previous
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Previous</span>
                        </li>
                    }

                    <!-- Page Numbers -->
                    @{
                        int startPage = Math.Max(1, Model.PageNumber - 2);
                        int endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);

                        if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, pageNumber = 1, pageSize = Model.PageSize })">
                                    1
                                </a>
                            </li>
                            if (startPage > 2)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                        }

                        for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == Model.PageNumber)
                            {
                                <li class="page-item active" aria-current="page">
                                    <span class="page-link">
                                        @i
                                        <span class="visually-hidden">(current)</span>
                                    </span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, pageNumber = i, pageSize = Model.PageSize })">
                                        @i
                                    </a>
                                </li>
                            }
                        }

                        if (endPage < Model.TotalPages)
                        {
                            if (endPage < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, pageNumber = Model.TotalPages, pageSize = Model.PageSize })">
                                    @Model.TotalPages
                                </a>
                            </li>
                        }
                    }

                    <!-- Next Button -->
                    @if (Model.HasNextPage)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, pageNumber = Model.PageNumber + 1, pageSize = Model.PageSize })">
                                Next
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Next</span>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <strong>No books found</strong>
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <p>No books match your search for "<strong>@Model.SearchQuery</strong>". Please try another search.</p>
            }
            else
            {
                <p>No books are available at the moment.</p>
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<style>
    .book-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .book-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }

    .book-card .card-title {
        font-weight: 600;
        line-height: 1.3;
        min-height: 2.6em;
    }

    .book-card .card-body {
        padding: 1rem;
    }
</style>
