@model HomePageViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="container-fluid py-5">
    <!-- Search Section -->
    <div class="row mb-5">
        <div class="col-md-8 offset-md-2">
            <form method="get" action="@Url.Action("Index", "Home")" class="input-group input-group-lg">
                <input 
                    type="text" 
                    name="searchTerm" 
                    class="form-control" 
                    placeholder="Search for books, authors, publishers, or genres..." 
                    value="@Model.SearchQuery"
                    aria-label="Search books" />
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search"></i> Search
                </button>
            </form>
        </div>
    </div>

    <!-- Books Section -->
    <div class="mb-5">
        <div class="row mb-4">
            <div class="col-12">
                @if (!string.IsNullOrEmpty(Model.SearchQuery))
                {
                    <h2><i class="bi bi-book"></i> Books - <span class="text-primary">@Model.SearchQuery</span></h2>
                }
                else
                {
                    <h2><i class="bi bi-book"></i> Featured Books</h2>
                }
                <p class="text-muted">
                    @if (Model.BookPagination.TotalCount == 0)
                    {
                        <span>No books found</span>
                    }
                    else
                    {
                        <span>
                            Showing @Model.BookPagination.StartIndex - @Model.BookPagination.EndIndex of @Model.BookPagination.TotalCount book(s)
                            @if (Model.BookPagination.TotalPages > 1)
                            {
                                <span> | Page @Model.BookPagination.PageNumber of @Model.BookPagination.TotalPages</span>
                            }
                        </span>
                    }
                </p>
            </div>
        </div>

        @if (Model.Books.Any())
        {
            <div class="row g-4">
                @foreach (var book in Model.Books)
                {
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <a href="@Url.Action("Detail", "Home", new { id = book.Id })" class="text-decoration-none">
                            <div class="card h-100 book-card" style="cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 1px 3px rgba(0,0,0,0.12)';">
                                <!-- Book Image -->
                                <div class="position-relative" style="height: 250px; overflow: hidden; background-color: #f5f5f5;">
                                    @if (!string.IsNullOrEmpty(book.ImageUrl))
                                    {
                                        <img 
                                            src="/@book.ImageUrl" 
                                            class="card-img-top" 
                                            alt="@book.Title"
                                            style="width: 100%; height: 100%; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center h-100">
                                            <span class="text-muted">
                                                <i class="bi bi-image" style="font-size: 3rem;"></i>
                                            </span>
                                        </div>
                                    }
                                </div>

                                <!-- Card Body -->
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title text-truncate text-dark" title="@book.Title">@book.Title</h5>
                                    
                                    @if (!string.IsNullOrEmpty(book.FirstAuthorName))
                                    {
                                        <p class="card-text text-muted small text-truncate" title="@book.FirstAuthorName">
                                            by @book.FirstAuthorName
                                        </p>
                                    }
                                    
                                    <div class="mt-auto">
                                        <div class="d-flex justify-content-between align-items-center gap-2">
                                            <span class="h5 mb-0 text-primary">$@book.Price.ToString("F2")</span>
                                            @if (Model.IsSignedIn)
                                            {
                                                <button class="btn btn-sm btn-outline-primary" type="button" onclick="event.preventDefault();">
                                                    <i class="bi bi-cart-plus"></i> Add to Cart
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <!-- Card Footer -->
                                <div class="card-footer bg-light border-top-0">
                                    <small class="text-muted d-block text-center">
                                        Click to view details
                                    </small>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>

            <!-- Books Pagination -->
            @if (Model.BookPagination.TotalPages > 1)
            {
                <nav aria-label="Book pagination" class="mt-4">
                    <ul class="pagination justify-content-center">
                        @if (Model.BookPagination.HasPreviousPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, bookPageNumber = Model.BookPagination.PageNumber - 1 })">
                                    Previous
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">Previous</span>
                            </li>
                        }

                        @for (int i = 1; i <= Model.BookPagination.TotalPages; i++)
                        {
                            if (i == Model.BookPagination.PageNumber)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, bookPageNumber = i })">
                                        @i
                                    </a>
                                </li>
                            }
                        }

                        @if (Model.BookPagination.HasNextPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, bookPageNumber = Model.BookPagination.PageNumber + 1 })">
                                    Next
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">Next</span>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                No books found @if (!string.IsNullOrEmpty(Model.SearchQuery)) { <text>for "<strong>@Model.SearchQuery</strong>"</text> }
            </div>
        }
    </div>

    <!-- Authors Section -->
    @if (Model.Authors.Any())
    {
        <div class="mb-5">
            <div class="row mb-4">
                <div class="col-12">
                    <h2><i class="bi bi-person"></i> Authors</h2>
                </div>
            </div>

            <div class="row g-4">
                @foreach (var author in Model.Authors)
                {
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <!-- todo: uncomment when ready <a href="@Url.Action("Detail", "Author", new { id = author.Id })" class="text-decoration-none"> -->
                        <a>

                            <div class="card h-100" style="cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 1px 3px rgba(0,0,0,0.12)';">
                                @if (!string.IsNullOrEmpty(author.ProfilePhotoUrl))
                                {
                                    <img src="~/@author.ProfilePhotoUrl" class="card-img-top" alt="@author.Name @author.Surname" style="height: 200px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                        <i class="bi bi-person" style="font-size: 3rem; color: #ccc;"></i>
                                    </div>
                                }
                                <div class="card-body">
                                    <h5 class="card-title text-dark">@author.Name @author.Surname</h5>
                                    <p class="card-text text-muted"><small>@author.BookCount book(s)</small></p>
                                </div>
                                <div class="card-footer bg-light border-top-0">
                                    <small class="text-muted d-block text-center">
                                        Click to view profile
                                    </small>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>

            <!-- Authors Pagination -->
            @if (Model.AuthorPagination.TotalPages > 1)
            {
                <nav aria-label="Author pagination" class="mt-4">
                    <ul class="pagination justify-content-center">
                        @if (Model.AuthorPagination.HasPreviousPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, authorPageNumber = Model.AuthorPagination.PageNumber - 1 })">
                                    Previous
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">Previous</span>
                            </li>
                        }

                        @for (int i = 1; i <= Model.AuthorPagination.TotalPages; i++)
                        {
                            if (i == Model.AuthorPagination.PageNumber)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, authorPageNumber = i })">
                                        @i
                                    </a>
                                </li>
                            }
                        }

                        @if (Model.AuthorPagination.HasNextPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, authorPageNumber = Model.AuthorPagination.PageNumber + 1 })">
                                    Next
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">Next</span>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    }

    <!-- Publishers Section -->
    @if (Model.Publishers.Any())
    {
        <div class="mb-5">
            <div class="row mb-4">
                <div class="col-12">
                    <h2><i class="bi bi-building"></i> Publishers</h2>
                </div>
            </div>

            <div class="row g-4">
                @foreach (var publisher in Model.Publishers)
                {
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <!-- todo: uncomment when ready<a href="@Url.Action("Detail", "Publisher", new { id = publisher.Id })" class="text-decoration-none"> -->
                        <a>

                            <div class="card h-100" style="cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 1px 3px rgba(0,0,0,0.12)';">
                                @if (!string.IsNullOrEmpty(publisher.ProfilePhotoUrl))
                                {
                                    <img src="~/@publisher.ProfilePhotoUrl" class="card-img-top" alt="@publisher.Name" style="height: 200px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                        <i class="bi bi-building" style="font-size: 3rem; color: #ccc;"></i>
                                    </div>
                                }
                                <div class="card-body">
                                    <h5 class="card-title text-dark">@publisher.Name</h5>
                                    <p class="card-text text-muted"><small>@publisher.BookCount book(s)</small></p>
                                </div>
                                <div class="card-footer bg-light border-top-0">
                                    <small class="text-muted d-block text-center">
                                        Click to view profile
                                    </small>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>

            <!-- Publishers Pagination -->
            @if (Model.PublisherPagination.TotalPages > 1)
            {
                <nav aria-label="Publisher pagination" class="mt-4">
                    <ul class="pagination justify-content-center">
                        @if (Model.PublisherPagination.HasPreviousPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, publisherPageNumber = Model.PublisherPagination.PageNumber - 1 })">
                                    Previous
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">Previous</span>
                            </li>
                        }

                        @for (int i = 1; i <= Model.PublisherPagination.TotalPages; i++)
                        {
                            if (i == Model.PublisherPagination.PageNumber)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, publisherPageNumber = i })">
                                        @i
                                    </a>
                                </li>
                            }
                        }

                        @if (Model.PublisherPagination.HasNextPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Home", new { searchTerm = Model.SearchQuery, publisherPageNumber = Model.PublisherPagination.PageNumber + 1 })">
                                    Next
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">Next</span>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    }
</div>

<style>
    .book-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .book-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }

    .book-card .card-title {
        font-weight: 600;
        line-height: 1.3;
        min-height: 2.6em;
    }

    .book-card .card-body {
        padding: 1rem;
    }
</style>

