@model BookDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-5">
    <h1 class="mb-4">@Model.Title</h1>

    <!-- Two Column Layout: Image and Details -->
    <div class="row mb-5">
        <!-- Left Column: Image -->
        <div class="col-lg-4 col-md-5 mb-4 mb-md-0">
            <div style="height: 600px; overflow: hidden; background-color: #f5f5f5; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img 
                        src="~/@Model.ImageUrl" 
                        alt="@Model.Title"
                        style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100">
                        <span class="text-muted">
                            <i class="bi bi-image" style="font-size: 5rem;"></i>
                        </span>
                    </div>
                }
            </div>
        </div>

        <!-- Right Column: Details -->
        <div class="col-lg-8 col-md-7">
            <!-- Authors -->
            @if (Model.Authors.Any())
            {
                <div class="mb-4">
                    <h5 class="text-muted mb-2">Authors</h5>
                    <div>
                        @foreach (var author in Model.Authors)
                        {
                            <span class="badge bg-info me-2 mb-2">@author.Name @author.Surname</span>
                        }
                    </div>
                </div>
            }

            <!-- Genres -->
            @if (Model.Genres.Any())
            {
                <div class="mb-4">
                    <h5 class="text-muted mb-2">Genres</h5>
                    <div>
                        @foreach (var genre in Model.Genres)
                        {
                            <a href="@Url.Action("Index", "Home", new { searchTerm = genre.Name })" class="badge bg-secondary me-2 mb-2 text-decoration-none" style="cursor: pointer;">@genre.Name</a>
                        }
                    </div>
                </div>
            }

            <!-- Publisher -->
            @if (Model.Publisher != null)
            {
                <div class="mb-4">
                    <h5 class="text-muted mb-2">Publisher</h5>
                    <p>@Model.Publisher.Name</p>
                </div>
            }

            <!-- Price and Add to Cart -->
            <div class="w-auto mb-4">
                <div class="mb-3">
                    <h3 class="text-primary mb-0">$@Model.Price.ToString("F2")</h3>
                </div>
                
                @if (Model.IsSignedIn)
                {
                    <div class="mb-3">
                        <label for="quantity" class="form-label">Quantity:</label>
                        <input 
                            type="number" 
                            id="quantity" 
                            name="quantity" 
                            class="form-control" 
                            value="1" 
                            min="1" 
                            max="999" 
                            style="width: 100px;" />
                    </div>

                    <button class="btn btn-primary btn-lg" type="button">
                        <i class="bi bi-cart-plus"></i> Add to Cart (Mock)
                    </button>
                }
                else
                {
                    <p class="text-muted mb-3">
                        <a href="@Url.Action("Login", "Account")" class="text-decoration-none">Sign in</a> to add items to your cart.
                    </p>
                }
            </div>
        </div>
    </div>

    <!-- Description -->
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <div class="row mb-5">
            <div class="col-12">
                <h3>Description</h3>
                <p class="text-justify">@Model.Description</p>
            </div>
        </div>
    }

    <!-- ISBN -->
    @if (!string.IsNullOrEmpty(Model.ISBN))
    {
        <div class="row mb-5">
            <div class="col-12">
                <h3>ISBN</h3>
                <p class="font-monospace">@Model.ISBN</p>
            </div>
        </div>
    }

    <!-- Ratings -->
    @if (Model.Ratings.Any())
    {
        <div class="row">
            <div class="col-12">
                <h3>User Ratings</h3>
                
                @if (Model.Ratings.Any())
                {
                    <div class="row">
                        @foreach (var rating in Model.Ratings.OrderByDescending(r => r.CreatedAt))
                        {
                            <div class="col-12 mb-3">
                                <div class="card">
                                    <div class="card-body">
                                        <div class="mb-2">
                                            @for (int i = 0; i < 5; i++)
                                            {
                                                @if (i < rating.Stars)
                                                {
                                                    <i class="bi bi-star-fill text-warning"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-star text-muted"></i>
                                                }
                                            }
                                            <small class="text-muted ms-2">@rating.Stars.0 / 5.0</small>
                                        </div>
                                        <small class="text-muted d-block">@rating.CreatedAt.ToString("dd-MM-yyyy HH:mm")</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">No ratings yet.</p>
                }
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12">
                <h3>User Ratings</h3>
                <p class="text-muted">No ratings yet.</p>
            </div>
        </div>
    }
</div>

