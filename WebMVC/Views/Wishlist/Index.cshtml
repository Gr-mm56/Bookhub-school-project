@model WebMVC.Models.WishlistViewModel

@{
    ViewData["Title"] = "My Wishlist";
    var items = Model?.WishlistItems ?? new List<WebMVC.Models.WishlistItemViewModel>();
}

<div class="container py-5" style="max-width: 80%;">
    <h1 class="mb-4">My Wishlist</h1>

    @if (items.Any())
    {
        <!-- Wishlist Items -->
        <div>
            @foreach (var item in items)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3">
                            <div>
                                <strong>@item.Title</strong>
                            </div>

                            <div class="text-nowrap ps-3">
                                <strong class="text-primary">$@item.Price.ToString("F2")</strong>
                            </div>

                            <div class="d-flex gap-2 flex-shrink-0 ms-auto">
                                <form asp-controller="Order"
                                      asp-action="AddFromWishlist"
                                      method="post" class="d-inline">
                                    <input type="hidden" name="bookId" value="@item.BookId"/>
                                    <button type="submit" class="btn btn-sm btn-link btn-primary">
                                        <i class="bi bi-cart-plus"></i> Add to Cart
                                    </button>
                                </form>

                                <form asp-action="RemoveFromWishlist"
                                      asp-controller="Wishlist"
                                      method="post">
                                    <input type="hidden" name="bookId" value="@item.BookId"/>
                                    <button class="btn btn-sm btn-link text-danger">
                                        Remove
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h3>Your wishlist is empty</h3>
            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-primary mt-3">
                Browse Books
            </a>
        </div>
    }
</div>
