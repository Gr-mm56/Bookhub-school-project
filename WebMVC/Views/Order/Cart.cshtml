@model WebMVC.Models.CartViewModel

@{
    ViewData["Title"] = "Shopping Cart";
    var items = Model?.PurchaseItems ?? new List<WebMVC.Models.CartItemViewModel>();
}

<div class="container py-5">
    <h1 class="mb-4">Shopping Cart</h1>

    @if (items.Any())
    {
        <div class="row">
            <!-- Cart Items -->
            <div class="col-lg-8">
                @foreach (var item in items)
                {
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="row align-items-center">

                                <div class="col-md-2 text-center">
                                    <strong>@item.Title</strong>
                                </div>

                                <div class="col-md-2 text-center">
                                    <form asp-action="UpdateQuantity" asp-controller="Order" method="post" class="d-flex align-items-center justify-content-center gap-1">
                                        <input type="hidden" name="bookId" value="@item.BookId" />

                                        <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control form-control-sm" style="width:60px;" />

                                        <button type="submit" class="btn btn-sm btn-outline-secondary">Update</button>
                                    </form>
                                </div>

                                <div class="col-md-2 text-center">
                                    <strong>$@item.Price.ToString("F2")</strong>
                                </div>

                                <div class="col-md-2 text-end">
                                    <strong class="text-primary">
                                        $@item.Subtotal.ToString("F2")
                                    </strong>
                                </div>
                                <div class="col-md-2 text-end">
                                    <form asp-action="RemoveFromCart"
                                          asp-controller="Order"
                                          method="post">
                                        <input type="hidden" name="bookId" value="@item.BookId"/>
                                        <button class="btn btn-sm btn-link text-danger">
                                            Remove
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Summary -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-body">
                        <h4>Order Summary</h4>
                        <hr />

                        @if (Model.GiftCardDiscount > 0)
                        {
                            <div class="d-flex justify-content-between">
                                <span>Original price</span>
                                <span>
                                    $@((Model.TotalValue + Model.GiftCardDiscount).ToString("F2"))
                                </span>
                            </div>

                            <div class="d-flex justify-content-between text-danger">
                                <span>Discount</span>
                                <span>
                                    - $@Model.GiftCardDiscount.ToString("F2")
                                </span>
                            </div>

                            <hr />

                            <div class="d-flex justify-content-between fw-bold">
                                <span>Total</span>
                                <span>
                                    $@Model.TotalValue.ToString("F2")
                                </span>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-between fw-bold">
                                <span>Total</span>
                                <span>
                                    $@Model.TotalValue.ToString("F2")
                                </span>
                            </div>
                        }

                        <a asp-action="Checkout"
                           asp-controller="Order"
                           class="btn btn-primary w-100 mt-3">
                            Proceed to Checkout
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h3>Your cart is empty</h3>
            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-primary mt-3">
                Browse Books
            </a>
        </div>
    }
</div>
<div class="container py-3">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Gift Card</h5>

                    <form asp-action="ApplyGiftCard" asp-controller="Order" method="post" class="d-flex gap-2">
                        <input type="text"
                               name="code"
                               class="form-control"
                               placeholder="Enter gift card code"
                               required />

                        <button type="submit" class="btn btn-outline-primary">
                            Apply
                        </button>
                    </form>

                    @if (TempData["GiftCardError"] != null)
                    {
                        <div class="text-danger mt-2">
                            @TempData["GiftCardError"]
                        </div>
                    }

                    @if (TempData["GiftCardSuccess"] != null)
                    {
                        <div class="text-success mt-2">
                            @TempData["GiftCardSuccess"]
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
