<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="card-title mb-4">Password Reset Link Sent</h2>
                    <p class="text-muted mb-4">
                        If an account exists with the provided email address, you will receive a password reset link shortly.
                    </p>

                    @if (TempData["ResetToken"] != null && TempData["ResetEmail"] != null)
                    {
                        <div class="alert alert-info text-start" role="alert">
                            <h5 class="alert-heading">Development Mode</h5>
                            <p class="mb-2">Since email is not configured, use this link to reset your password:</p>
                            <a asp-action="ResetPassword" 
                               asp-route-token="@TempData["ResetToken"]" 
                               asp-route-email="@TempData["ResetEmail"]" 
                               class="btn btn-sm btn-primary">
                                Reset Password Now
                            </a>
                        </div>
                    }

                    <hr class="my-4">

                    <a asp-action="Login" class="btn btn-outline-primary">Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</div>

