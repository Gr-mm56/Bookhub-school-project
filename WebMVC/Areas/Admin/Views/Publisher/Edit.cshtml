@model WebMVC.Areas.Admin.Models.Publisher.PublisherCreateEditViewModelWithOptions

@{
    ViewBag.Title = "Edit Publisher";
    Layout = "_Layout";
    var publisherId = ViewBag.PublisherId;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header">
                    <h3>Edit Publisher #@publisherId</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" asp-route-id="@publisherId" method="post" id="editPublisherForm" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row">
                            @await Html.PartialAsync("_FormBasicFields", Model)
                        </div>

                        <div class="row">
                            @await Html.PartialAsync("_FormProfilePhoto", Model)
                        </div>

                        @await Html.PartialAsync("_FormMultiselects", Model)

                        <div class="alert alert-info mt-3">
                            <i class="bi bi-info-circle"></i>
                            <strong>Note:</strong> To remove a book from this publisher, please go to the book's edit page and remove the publisher from there.
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-primary" id="submitBtn">
                                <i class="bi bi-save"></i> Update Publisher
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    @{
        ViewBag.FormId = "editPublisherForm";
        ViewBag.SubmitBtnId = "submitBtn";
    }
    @await Html.PartialAsync("_FormValidationScript")
}