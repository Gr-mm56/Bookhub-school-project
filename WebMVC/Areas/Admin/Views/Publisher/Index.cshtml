@model WebMVC.Areas.Admin.Models.Publisher.PublisherViewModel

@{
    ViewBag.Title = "Publishers Management";
    Layout = "_Layout";
    var currentPage = (int?)ViewBag.CurrentPage ?? 1;
    var totalPages = (int?)ViewBag.TotalPages ?? 1;
    var totalCount = (int?)ViewBag.TotalCount ?? 0;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Publishers Management</h2>
        <a asp-area="Admin" asp-action="Create" asp-controller="Publisher" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Publisher
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Publishers != null && Model.Publishers.Any())
    {
        <div class="card">
            <div class="card-body">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Address</th>
                            <th>Books</th>
                            <th>Created At</th>
                            <th>Updated At</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var publisher in Model.Publishers)
                        {
                            <tr>
                                <td>@publisher.Id</td>
                                <td>@publisher.Name</td>
                                <td>@publisher.Address</td>
                                <td><span class="badge bg-info">@publisher.BookCount</span></td>
                                <td>@publisher.CreatedAt.ToString("dd-MM-yyyy")</td>
                                <td>@publisher.UpdatedAt.ToString("dd-MM-yyyy")</td>
                                <td class="text-end">
                                    <a asp-area="Admin" asp-action="Edit" asp-controller="Publisher" asp-route-id="@publisher.Id" class="btn btn-sm btn-warning me-1">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-area="Admin" asp-action="Delete" asp-controller="Publisher" asp-route-id="@publisher.Id" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">
                    @if (currentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="1" title="First page">
                                <i class="bi bi-chevron-double-left"></i>
                            </a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" title="Previous page">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                    }

                    @for (var i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                    {
                        if (i == currentPage)
                        {
                            <li class="page-item active">
                                <span class="page-link">@i</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                @{ 
                                    var index = i;
                                }
                                <a class="page-link" asp-action="Index" asp-route-page="@index">@index</a>
                            </li>
                        }
                    }

                    @if (currentPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" title="Next page">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@totalPages" title="Last page">
                                <i class="bi bi-chevron-double-right"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>

            <div class="text-center text-muted small">
                Showing page @currentPage of @totalPages (@Model.Publishers.Count items on this page, @totalCount total items)
            </div>
        }
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No publishers found. Click "Add New Publisher" to create one.
        </div>
    }
</div>