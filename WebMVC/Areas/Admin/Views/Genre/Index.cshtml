@model WebMVC.Areas.Admin.Models.Genre.GenresViewModel

@{
    ViewBag.Title = "Genres Management";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Genres Management</h2>
        <a asp-area="Admin" asp-action="Create" asp-controller="Genre" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Genre
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model?.Genres != null && Model.Genres.Any())
    {
        <div class="card">
            <div class="card-body">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Created At</th>
                            <th>Updated At</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var genre in Model.Genres)
                        {
                            <tr>
                                <td>@genre.Id</td>
                                <td>@genre.Name</td>
                                <td>@genre.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@genre.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end">
                                    <a asp-area="Admin" asp-action="Edit" asp-controller="Genre" asp-route-id="@genre.Id" class="btn btn-sm btn-warning me-1">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-area="Admin" asp-action="Delete" asp-controller="Genre" asp-route-id="@genre.Id" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No genres found. Click "Add New Genre" to create one.
        </div>
    }
</div>
