@model BusinessLayer.Models.Genre.Requests.GenreRequestDto

@{
    ViewBag.Title = "Edit Genre";
    Layout = "_Layout";
    var genreId = ViewBag.GenreId;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3>Edit Genre #@genreId</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" asp-route-id="@genreId" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Genre Name</label>
                            <input asp-for="Name" class="form-control" placeholder="Enter genre name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Update Genre
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

