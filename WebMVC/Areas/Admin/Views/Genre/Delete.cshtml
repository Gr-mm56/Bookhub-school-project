@model WebMVC.Areas.Admin.Models.Genre.GenreDeleteViewModel

@{
    ViewBag.Title = "Delete Genre";
    Layout = "_Layout";
    
    var isUsedAsPrimary = Model.PrimaryBooks != null && Model.PrimaryBooks.Any();
    var isUsedInAnyBook = Model.AssociatedBooks != null && Model.AssociatedBooks.Any();
    var deleteDisabled = isUsedAsPrimary || isUsedInAnyBook;

}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h3>Delete Genre</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i>
                        <strong>Warning!</strong> Are you sure you want to delete this genre?
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">ID:</dt>
                        <dd class="col-sm-8">@Model.Id</dd>

                        <dt class="col-sm-4">Name:</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">Created At:</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("dd-MM-yyyy")</dd>

                        <dt class="col-sm-4">Updated At:</dt>
                        <dd class="col-sm-8">@Model.UpdatedAt.ToString("dd-MM-yyyy")</dd>

                        @if (Model.PrimaryBooks != null && Model.PrimaryBooks.Any())
                        {
                            <dt class="col-sm-4">Primary Books:</dt>
                            <dd class="col-sm-8">
                                <ul class="list-unstyled mb-0">
                                    @foreach (var book in Model.PrimaryBooks)
                                    {
                                        <li><span class="badge bg-warning">ID: @book.Id</span> @book.Title</li>
                                    }
                                </ul>
                            </dd>
                        }

                        @if (Model.AssociatedBooks != null && Model.AssociatedBooks.Any())
                        {
                            <dt class="col-sm-4">Associated Books:</dt>
                            <dd class="col-sm-8">
                                <ul class="list-unstyled mb-0">
                                    @foreach (var book in Model.AssociatedBooks)
                                    {
                                        <li><span class="badge bg-info">ID: @book.Id</span> @book.Title</li>
                                    }
                                </ul>
                            </dd>
                        }
                    </dl>
                    @if (deleteDisabled)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-x-circle"></i>
                            This genre cannot be deleted while it is assigned to books. Remove the genre from the listed books or change their primary genre first.
                        </div>
                    }
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger" @(deleteDisabled ? "disabled=\"disabled\" aria-disabled=\"true\"" : String.Empty)>
                                <i class="bi bi-trash"></i> Confirm Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

