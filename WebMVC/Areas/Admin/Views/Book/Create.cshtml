@model WebMVC.Areas.Admin.Models.Book.BookCreateEditViewModelWithOptions

@{
    ViewBag.Title = "Create Book";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header">
                    <h3>Create New Book</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" id="createBookForm" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row">
                            <!-- Title -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Book.Title" class="form-label">Title *</label>
                                <input asp-for="Book.Title" class="form-control" placeholder="Enter book title" />
                                <span asp-validation-for="Book.Title" class="text-danger small d-block mt-1"></span>
                            </div>

                            <!-- ISBN -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Book.ISBN" class="form-label">ISBN *</label>
                                <input asp-for="Book.ISBN" class="form-control" placeholder="Enter ISBN" />
                                <span asp-validation-for="Book.ISBN" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label asp-for="Book.Description" class="form-label">Description</label>
                            <textarea asp-for="Book.Description" class="form-control" rows="3" placeholder="Enter book description"></textarea>
                            <span asp-validation-for="Book.Description" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="row">
                            <!-- Price -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Book.Price" class="form-label">Price ($) *</label>
                                <input asp-for="Book.Price" class="form-control" type="number" step="0.01" min="0.01" placeholder="0.00" />
                                <span asp-validation-for="Book.Price" class="text-danger small d-block mt-1"></span>
                            </div>

                            <!-- Primary Genre -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Book.PrimaryGenreId" class="form-label">Primary Genre *</label>
                                <select asp-for="Book.PrimaryGenreId" class="form-select">
                                    <option value="">-- Select Primary Genre --</option>
                                    @foreach (var genre in Model.Genres)
                                    {
                                        <option value="@genre.Id">@genre.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="Book.PrimaryGenreId" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Image -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Book.ImageId" class="form-label">Image</label>
                                <select asp-for="Book.ImageId" class="form-select">
                                    <option value="">-- Select Image (Optional) --</option>
                                    @foreach (var image in Model.Images)
                                    {
                                        <option value="@image.Id">@image.FileName</option>
                                    }
                                </select>
                                <span asp-validation-for="Book.ImageId" class="text-danger small d-block mt-1"></span>
                            </div>

                            <!-- Publisher -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Book.PublisherId" class="form-label">Publisher</label>
                                <select asp-for="Book.PublisherId" class="form-select">
                                    <option value="">-- Select Publisher (Optional) --</option>
                                    @foreach (var publisher in Model.Publishers)
                                    {
                                        <option value="@publisher.Id">@publisher.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="Book.PublisherId" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>

                        <!-- Genres Multiselect -->
                        <div class="mb-3">
                            <label asp-for="Book.GenreIds" class="form-label">Additional Genres *</label>
                            <select asp-for="Book.GenreIds" class="form-select" multiple="multiple" style="height: 150px;">
                                @foreach (var genre in Model.Genres)
                                {
                                    <option value="@genre.Id">@genre.Name</option>
                                }
                            </select>
                            <small class="text-muted d-block mt-1">Hold Ctrl (Cmd on Mac) to select multiple genres</small>
                            <span asp-validation-for="Book.GenreIds" class="text-danger small d-block mt-1"></span>
                        </div>

                        <!-- Authors Multiselect -->
                        <div class="mb-3">
                            <label asp-for="Book.AuthorIds" class="form-label">Authors *</label>
                            <select asp-for="Book.AuthorIds" class="form-select" multiple="multiple" style="height: 150px;">
                                @foreach (var author in Model.Authors)
                                {
                                    <option value="@author.Id">@author.Name</option>
                                }
                            </select>
                            <small class="text-muted d-block mt-1">Hold Ctrl (Cmd on Mac) to select multiple authors</small>
                            <span asp-validation-for="Book.AuthorIds" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-primary" id="submitBtn">
                                <i class="bi bi-save"></i> Create Book
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('createBookForm');
            const submitBtn = document.getElementById('submitBtn');

            // Update submit button based on form validity
            function updateSubmitButtonState() {
                const titleInput = form.querySelector('input[name="Book.Title"]');
                const isbnInput = form.querySelector('input[name="Book.ISBN"]');
                const priceInput = form.querySelector('input[name="Book.Price"]');
                const primaryGenreSelect = form.querySelector('select[name="Book.PrimaryGenreId"]');
                const genreMultiselect = form.querySelector('select[name="Book.GenreIds"]');
                const authorMultiselect = form.querySelector('select[name="Book.AuthorIds"]');
                
                let isValid = true;

                // Check title
                if (!titleInput.value.trim()) {
                    isValid = false;
                }

                // Check ISBN
                if (!isbnInput.value.trim()) {
                    isValid = false;
                }

                // Check price
                const price = parseFloat(priceInput.value);
                if (!priceInput.value || isNaN(price) || price <= 0) {
                    isValid = false;
                }

                // Check Primary Genre
                if (primaryGenreSelect.value === '') {
                    isValid = false;
                }

                // Check Genres multiselect
                if (genreMultiselect.selectedOptions.length === 0) {
                    isValid = false;
                }

                // Check Authors multiselect
                if (authorMultiselect.selectedOptions.length === 0) {
                    isValid = false;
                }

                submitBtn.disabled = !isValid;
            }

            // Update on form changes
            form.addEventListener('change', updateSubmitButtonState);
            form.addEventListener('input', updateSubmitButtonState);
            form.addEventListener('keyup', updateSubmitButtonState);

            // Before form submission, ensure multiselect values are properly set
            form.addEventListener('submit', function(e) {
                const genreMultiselect = form.querySelector('select[name="Book.GenreIds"]');
                const authorMultiselect = form.querySelector('select[name="Book.AuthorIds"]');
                
                // Ensure all selected options in multiselects are marked as selected
                Array.from(genreMultiselect.options).forEach(option => {
                    if (Array.from(genreMultiselect.selectedOptions).includes(option)) {
                        option.selected = true;
                    }
                });
                
                Array.from(authorMultiselect.options).forEach(option => {
                    if (Array.from(authorMultiselect.selectedOptions).includes(option)) {
                        option.selected = true;
                    }
                });
            });

            // Initial state
            updateSubmitButtonState();
        });
    </script>
}

