@model List<WebMVC.Areas.Admin.Models.Image.ImageListItemViewModel>
@{
    ViewBag.Title = "Image Management";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-6">Image Management</h1>
            <p class="text-muted">Manage uploaded images</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-area="Admin" asp-controller="Image" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-cloud-upload"></i> Upload Image
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model != null && Model.Count > 0)
    {
        <div class="card">
            <div class="card-header bg-light">
                <span class="badge bg-info">@ViewBag.TotalCount total image(s)</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>File URL</th>
                            <th>Created</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var image in Model)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-secondary">@image.Id</span>
                                </td>
                                <td>
                                    <code>@image.FileUrl</code>
                                </td>
                                <td>
                                    <small class="text-muted">@image.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                                </td>
                                <td>
                                    <a asp-area="Admin" asp-controller="Image" asp-action="Detail" asp-route-id="@image.Id" class="btn btn-sm btn-info">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    <a asp-area="Admin" asp-controller="Image" asp-action="Delete" asp-route-id="@image.Id" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination Section -->
        @if ((int)ViewBag.TotalPages > 1)
        {
            <nav aria-label="Pagination" class="mt-4">
                <ul class="pagination justify-content-center">
                    <!-- Previous Button -->
                    @if ((int)ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", "Image", new { area = "Admin", page = ViewBag.CurrentPage - 1 })">
                                Previous
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Previous</span>
                        </li>
                    }

                    <!-- Page Numbers -->
                    @{
                        int startPage = Math.Max(1, (int)ViewBag.CurrentPage - 2);
                        int endPage = Math.Min((int)ViewBag.TotalPages, (int)ViewBag.CurrentPage + 2);

                        if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Image", new { area = "Admin", page = 1 })">1</a>
                            </li>
                            if (startPage > 2)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                        }

                        for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == (int)ViewBag.CurrentPage)
                            {
                                <li class="page-item active" aria-current="page">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Index", "Image", new { area = "Admin", page = i })">@i</a>
                                </li>
                            }
                        }

                        if (endPage < (int)ViewBag.TotalPages)
                        {
                            if (endPage < (int)ViewBag.TotalPages - 1)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Image", new { area = "Admin", page = ViewBag.TotalPages })">
                                    @ViewBag.TotalPages
                                </a>
                            </li>
                        }
                    }

                    <!-- Next Button -->
                    @if ((int)ViewBag.CurrentPage < (int)ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", "Image", new { area = "Admin", page = ViewBag.CurrentPage + 1 })">
                                Next
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Next</span>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info">
            <p>No images uploaded yet. <a asp-area="Admin" asp-controller="Image" asp-action="Create" class="alert-link">Upload an image</a> to get started.</p>
        </div>
    }
</div>

