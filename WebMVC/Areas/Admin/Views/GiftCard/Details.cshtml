@model WebMVC.Areas.Admin.Models.GiftCard.GiftCardDeleteViewModel

@{
    ViewBag.Title = "Gift Card Details";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header">
                    <h3>Gift Card Details #@Model.Id</h3>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">ID:</dt>
                        <dd class="col-sm-9">@Model.Id</dd>

                        <dt class="col-sm-3">Price Reduction:</dt>
                        <dd class="col-sm-9"><strong class="text-success">$@Model.PriceReduction.ToString("N2")</strong></dd>

                        <dt class="col-sm-3">Valid Period:</dt>
                        <dd class="col-sm-9">
                            @Model.ValidFrom.ToString("dd-MM-yyyy") - @Model.ValidTo.ToString("dd-MM-yyyy")
                        </dd>

                        <dt class="col-sm-3">Status:</dt>
                        <dd class="col-sm-9">
                            @{
                                var now = DateTime.UtcNow;
                                var isActive = now >= Model.ValidFrom && now <= Model.ValidTo;
                            }
                            @if (isActive)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> Active
                                </span>
                            }
                            else if (now < Model.ValidFrom)
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-clock"></i> Pending
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-x-circle"></i> Expired
                                </span>
                            }
                        </dd>

                        <dt class="col-sm-3">Total Coupons:</dt>
                        <dd class="col-sm-9"><span class="badge bg-info">@Model.TotalCoupons</span></dd>

                        <dt class="col-sm-3">Used Coupons:</dt>
                        <dd class="col-sm-9">
                            @if (Model.UsedCoupons > 0)
                            {
                                <span class="badge bg-danger">@Model.UsedCoupons</span>
                            }
                            else
                            {
                                <span class="badge bg-success">None</span>
                            }
                        </dd>

                        <dt class="col-sm-3">Available Coupons:</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-success">@(Model.TotalCoupons - Model.UsedCoupons)</span>
                        </dd>

                        <dt class="col-sm-3">Created At:</dt>
                        <dd class="col-sm-9">@Model.CreatedAt.ToString("dd-MM-yyyy HH:mm")</dd>

                        <dt class="col-sm-3">Updated:</dt>
                        <dd class="col-sm-9">@Model.UpdatedAt.ToString("dd-MM-yyyy HH:mm")</dd>
                    </dl>

                    <hr class="my-4" />

                    <h4 class="mb-3">
                        <i class="bi bi-ticket-perforated"></i> All Coupon Codes (@Model.TotalCoupons)
                    </h4>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Coupon Code</th>
                                    <th>Status</th>
                                    <th>Linked Order</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var index = 1;
                                    var sortedCoupons = Model.Coupons
                                        .OrderByDescending(c => c.IsUsed)
                                        .ThenBy(c => c.Code)
                                        .ToList();
                                }
                                @foreach (var coupon in sortedCoupons)
                                {
                                    <tr class="@(coupon.IsUsed ? "table-secondary" : "")">
                                        <td>@index</td>
                                        <td>
                                            <code class="@(coupon.IsUsed ? "text-muted" : "text-primary")">
                                                @coupon.Code
                                            </code>
                                        </td>
                                        <td>
                                            @if (coupon.IsUsed)
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-x-circle"></i> Used
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-circle"></i> Available
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (coupon.IsUsed && coupon.UsedInOrderId.HasValue)
                                            {
                                                <a asp-area="Admin" 
                                                   asp-controller="Order" 
                                                   asp-action="Edit" 
                                                   asp-route-id="@coupon.UsedInOrderId" 
                                                   class="badge bg-info text-decoration-none"
                                                   title="View Order Details">
                                                    <i class="bi bi-box-seam"></i> Order #@coupon.UsedInOrderId
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                    index++;
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.UsedCoupons > 0)
                    {
                        <div class="alert alert-info mt-3">
                            <i class="bi bi-info-circle"></i>
                            <strong>Note:</strong> @Model.UsedCoupons out of @Model.TotalCoupons coupon codes have been used in orders. 
                            Click on the order badge to view order details.
                        </div>
                    }

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                        <div>
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>