@model WebMVC.Areas.Admin.Models.GiftCard.GiftCardCreateEditViewModel

@{
    ViewBag.Title = "Edit Gift Card";
    Layout = "_Layout";
    var giftCardId = ViewBag.GiftCardId;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header">
                    <h3>Edit Gift Card #@giftCardId</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" asp-route-id="@giftCardId" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PriceReduction" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="PriceReduction" class="form-control" type="number" step="0.01" min="0.01" />
                                </div>
                                <span asp-validation-for="PriceReduction" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Current Coupons</label>
                                <input type="text" class="form-control" value="@Model.NumberOfCoupons codes" readonly disabled />
                                <small class="form-text text-muted">
                                    <i class="bi bi-info-circle"></i> Already generated coupons
                                </small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ValidFrom" class="form-label"></label>
                                <input asp-for="ValidFrom" class="form-control" type="date" />
                                <span asp-validation-for="ValidFrom" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="ValidTo" class="form-label"></label>
                                <input asp-for="ValidTo" class="form-control" type="date" />
                                <span asp-validation-for="ValidTo" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="AdditionalCoupons" class="form-label"></label>
                                <input asp-for="AdditionalCoupons" class="form-control" type="number" min="0" max="1000" />
                                <span asp-validation-for="AdditionalCoupons" class="text-danger small"></span>
                                <small class="form-text text-muted">
                                    <i class="bi bi-info-circle"></i> Generate additional coupon codes if needed. Leave at 0 to not add any.
                                </small>
                            </div>
                        </div>

                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i>
                            <strong>Warning:</strong> Already used coupons cannot be removed or modified.
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Update Gift Card
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}