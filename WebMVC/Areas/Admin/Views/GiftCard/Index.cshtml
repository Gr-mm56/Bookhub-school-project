@model WebMVC.Areas.Admin.Models.GiftCard.GiftCardViewModel

@{
    ViewBag.Title = "Gift Cards Management";
    Layout = "_Layout";
    var currentPage = (int?)ViewBag.CurrentPage ?? 1;
    var totalPages = (int?)ViewBag.TotalPages ?? 1;
    var totalCount = (int?)ViewBag.TotalCount ?? 0;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gift Cards Management</h2>
        <a asp-area="Admin" asp-action="Create" asp-controller="GiftCard" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Gift Card
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.GiftCards != null && Model.GiftCards.Any())
    {
        <div class="card">
            <div class="card-body">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Price Reduction</th>
                            <th>Valid From</th>
                            <th>Valid To</th>
                            <th>Coupons</th>
                            <th>Status</th>
                            <th>Created At</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.GiftCards)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td><strong>$@item.PriceReduction.ToString("N2")</strong></td>
                                <td>@item.ValidFrom.ToString("dd-MM-yyyy")</td>
                                <td>@item.ValidTo.ToString("dd-MM-yyyy")</td>
                                <td>
                                    <span class="badge bg-info" title="Total Coupons">
                                        <i class="bi bi-ticket-perforated"></i> @item.TotalCoupons
                                    </span>
                                    <span class="badge bg-success" title="Available">
                                        <i class="bi bi-check-circle"></i> @item.AvailableCoupons
                                    </span>
                                    <span class="badge bg-secondary" title="Used">
                                        <i class="bi bi-x-circle"></i> @item.UsedCoupons
                                    </span>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Active
                                        </span>
                                    }
                                    else if (DateTime.UtcNow < item.ValidFrom)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-clock"></i> Pending
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-x-circle"></i> Expired
                                        </span>
                                    }
                                </td>
                                <td>@item.CreatedAt.ToString("dd-MM-yyyy")</td>
                                <td class="text-end">
                                    <a asp-area="Admin" asp-action="Details" asp-controller="GiftCard" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1" title="View Details">
                                        <i class="bi bi-eye"></i> Details
                                    </a>
                                    <a asp-area="Admin" asp-action="Edit" asp-controller="GiftCard" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1" title="Edit">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-area="Admin" asp-action="Delete" asp-controller="GiftCard" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">
                    @if (currentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="1" title="First page">
                                <i class="bi bi-chevron-double-left"></i>
                            </a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" title="Previous page">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                    }

                    @for (var i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                    {
                        if (i == currentPage)
                        {
                            <li class="page-item active">
                                <span class="page-link">@i</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                @{ 
                                    var index = i;
                                }
                                <a class="page-link" asp-action="Index" asp-route-page="@index">@index</a>
                            </li>
                        }
                    }

                    @if (currentPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" title="Next page">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@totalPages" title="Last page">
                                <i class="bi bi-chevron-double-right"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>

            <div class="text-center text-muted small">
                Showing page @currentPage of @totalPages (@Model.GiftCards.Count items on this page, @totalCount total items)
            </div>
        }
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No gift cards found. Click "Add New Gift Card" to create one.
        </div>
    }
</div>